# Private key used to encrypt session cookie (minimum 32 characters)
SESSION_SECRET=
# GitHub OAuth client ID
GITHUB_OAUTH_CLIENT_ID=
# GitHub OAuth client secret
GITHUB_OAUTH_CLIENT_SECRET=
# Vercel AI gateway key (chat streaming)
AI_GATEWAY_API_KEY=
# Turso database URL (only needed in production)
TURSO_DATABASE_URL=
# Turso auth token (only needed in production)
TURSO_AUTH_TOKEN=

# ---- Voice (STT + TTS) ----
# Choose the provider used by /api/voice/transcribe and /api/voice/speak.
# openai (default) or azure
VOICE_PROVIDER=openai
# Required when VOICE_PROVIDER=openai
OPENAI_API_KEY=
# Optional: override OpenAI voice models / default voice
# OPENAI_STT_MODEL=gpt-4o-mini-transcribe
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=alloy
# Required when VOICE_PROVIDER=azure
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# Optional Azure TTS voice (default en-US-AvaNeural)
# AZURE_TTS_VOICE=en-US-AvaNeural
# Optional Azure STT language (default en-US)
# AZURE_STT_LANGUAGE=en-US
